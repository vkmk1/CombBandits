\newlabel{fig:ablation_sigma}{{1}{5}{Effect of gate scale $\sigma _g$ on consistent-wrong regret at $T = 30{,}000$, $d = 100$, $m = 10$. Smaller $\sigma _g$ produces a sharper gate and lower worst-case regret without harming reliable-oracle regret}{figure.caption.3}{}}
\newlabel{sec:experiments_ablations}{{6.3}{5}{}{subsection.6.3}{}}
\citation{krishnamurthy2024canllms,bayley2025jumpstart,park2025regret}
\newlabel{tab:main}{{1}{6}{Cumulative regret at $T = 20{,}000$ on the \textsc {uniform} environment with $d = 100$, $m = 10$. Mean $\pm $ standard deviation across $50$ random seeds. Lower is better}{table.caption.1}{}}
\newlabel{tab:gaps}{{2}{6}{Generalization across gap structures (\textsc {uniform}, \textsc {clustered}, \textsc {graded}). Mean regret at $T=20{,}000$ across $30$ seeds, $d=100$, $m=10$}{table.caption.2}{}}
\newlabel{fig:ablation_init}{{2}{6}{Effect of round-robin init horizon $T_{\mathrm {init}}$ on perfect (left) and consistent-wrong (right) regret. The trade-off is monotone in both directions but flattens for $T_{\mathrm {init}} \geq 200$}{figure.caption.4}{}}
\newlabel{sec:discussion}{{7}{6}{}{section.7}{}}
\newlabel{fig:lowerbound}{{3}{6}{Cumulative regret under consistent-wrong oracle. LLM-CUCB-AT scales linearly with $T$ as predicted by Theorem~\ref {thm:lowerbound}. \algname {} matches the logarithmic scaling of vanilla CUCB because the calibration gate routes to full Thompson sampling once the pool's failure is empirically evident}{figure.caption.5}{}}
