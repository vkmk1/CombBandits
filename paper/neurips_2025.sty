% neurips_2025.sty - Style file for NeurIPS 2025
% Based on the standard NeurIPS formatting requirements

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 Style]

\newif\if@accepted
\DeclareOption{accepted}{\@acceptedtrue}
\newif\if@preprint
\DeclareOption{preprint}{\@preprinttrue}
\newif\if@final
\DeclareOption{final}{\@finaltrue}
\newif\if@nonatbib
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% Fonts and encoding
\RequirePackage{times}

% Page layout
\RequirePackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
}

% Line spacing
\RequirePackage{setspace}
\setstretch{1.0}

% Natbib
\if@nonatbib\else
  \RequirePackage[numbers,sort&compress]{natbib}
\fi

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Paragraphs
\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}

% Title and author
\def\@maketitle{%
  \newpage
  \null
  \vskip 2em
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 1.5em%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 1em%
  \end{center}%
  \par
  \vskip 1.5em}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}%
  \small
}{%
  \par
  \end{quote}%
  \vskip 1ex%
}

% And/corresponding author separator
\newcommand{\And}{%
  \end{tabular}%
  \hfil%
  \begin{tabular}[t]{c}%
}
% \AND removed to avoid conflicts

\endinput
